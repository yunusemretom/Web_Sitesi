<%- include('partials/footer') %>

<style>
.page-hero { background: var(--bg-card); border-bottom: 1px solid var(--border); padding-top: 1rem; }
.page-hero-inner { padding-bottom: 3rem; }
.page-hero h1 em { font-style: italic; color: var(--gold); }
.page-hero-sub { color: var(--text-muted); margin-top: 1rem; font-size: 1rem; }

.contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }

.contact-item { margin-bottom: 2.5rem; }
.contact-item-label { font-family: var(--mono); font-size: 0.65rem; color: var(--gold); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.5rem; }
.contact-item-value { font-size: 1.05rem; color: var(--text); }
a.contact-item-value { transition: color var(--transition); }
a.contact-item-value:hover { color: var(--gold); }
.available { display: flex; align-items: center; gap: 0.6rem; }
.available-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,0.5); animation: pulse-green 2s infinite; }
@keyframes pulse-green { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.7;transform:scale(1.2)} }

.socials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.social-card {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.85rem 1rem;
  background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text-muted); font-family: var(--mono); font-size: 0.72rem;
  letter-spacing: 0.06em; text-transform: uppercase;
  transition: all var(--transition);
}
.social-card:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); transform: translateY(-2px); }

.contact-cta-col { display: flex; flex-direction: column; gap: 1.5rem; }
.contact-cta-card {
  background: var(--bg-card); border: 1px solid var(--border);
  padding: 2.5rem; display: flex; flex-direction: column; gap: 1rem;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.contact-cta-card:hover { border-color: var(--border-hover); box-shadow: 0 8px 30px rgba(0,0,0,0.2); }
.cta-icon { color: var(--gold); margin-bottom: 0.5rem; }
.contact-cta-card h3 { font-size: 1.2rem; }
.contact-cta-card p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.7; }

@media (max-width: 900px) { .contact-layout { grid-template-columns: 1fr; gap: 3rem; } }
</style>

<script src="/js/main.js"></script>
<script src="/js/animations.js"></script>
</body>
</html>
